    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#808080",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["comment.block.documentation"],
            "settings": {
                "foreground": "#629755",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "string.quoted"],
            "settings": {
                "foreground": "#6A8759"
            }
        },
        {
            "scope": ["string.regexp"],
            "settings": {
                "foreground": "#CC7832"
            }
        },
        {
            "scope": ["constant.character.escape"],
            "settings": {
                "foreground": "#CC7832"
            }
        },
        {
            "scope": ["constant.numeric", "constant.language"],
            "settings": {
                "foreground": "#6897BB"
            }
        },
        {
            "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
            "settings": {
                "foreground": "#CC7832",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["constant.other", "variable.other.constant", "entity.name.constant"],
            "settings": {
                "foreground": "#9876AA"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.logical",
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#CC7832",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["keyword.operator"],
            "settings": {
                "foreground": "#D4D4D4"
            }
        },
        {
            "scope": ["keyword.other.trait.ato", "keyword.control.directive.pragma.ato"],
            "settings": {
                "foreground": "#F95015",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "entity.name.type.class", "support.class", "support.type"],
            "settings": {
                "foreground": "#FFC66D"
            }
        },
        {
            "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
            "settings": {
                "foreground": "#FFC66D"
            }
        },
        {
            "scope": ["entity.name.function.constructor.ato"],
            "settings": {
                "foreground": "#FFC66D",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["entity.name.tag"],
            "settings": {
                "foreground": "#E8BF6A"
            }
        },
        {
            "scope": ["entity.other.attribute-name"],
            "settings": {
                "foreground": "#BABABA"
            }
        },
        {
            "scope": ["entity.name.namespace", "entity.name.module"],
            "settings": {
                "foreground": "#D4D4D4"
            }
        },
        {
            "scope": ["variable", "variable.other"],
            "settings": {
                "foreground": "#D4D4D4"
            }
        },
        {
            "scope": ["variable.parameter"],
            "settings": {
                "foreground": "#D4D4D4"
            }
        },
        {
            "scope": ["variable.language.self", "variable.language.this"],
            "settings": {
                "foreground": "#94558D",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["variable.other.property", "variable.other.member", "meta.object-literal.key"],
            "settings": {
                "foreground": "#9876AA"
            }
        },
        {
            "scope": ["support.variable", "support.constant"],
            "settings": {
                "foreground": "#9876AA"
            }
        },
        {
            "scope": ["punctuation"],
            "settings": {
                "foreground": "#D4D4D4"
            }
        },
        {
            "scope": ["punctuation.separator.double-colon.ato"],
            "settings": {
                "foreground": "#F95015"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#FF6B68",
                "fontStyle": "underline"
            }
        },
        {
            "scope": ["invalid.deprecated"],
            "settings": {
                "foreground": "#D4D4D4",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": ["markup.heading"],
            "settings": {
                "foreground": "#F95015",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.bold"],
            "settings": {
                "foreground": "#FFC66D",
                "fontStyle": "bold"
            }
        },
        {
            "scope": ["markup.italic"],
            "settings": {
                "foreground": "#D4D4D4",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["markup.underline.link", "string.other.link"],
            "settings": {
                "foreground": "#F95015",
                "fontStyle": "underline"
            }
        },
        {
            "scope": ["markup.inserted"],
            "settings": {
                "foreground": "#629755"
            }
        },
        {
            "scope": ["markup.deleted"],
            "settings": {
                "foreground": "#CC666E"
            }
        },
        {
            "scope": ["markup.changed"],
            "settings": {
                "foreground": "#CC7832"
            }
        },
        {
            "scope": ["markup.raw", "markup.inline.raw"],
            "settings": {
                "foreground": "#6A8759"
            }
        },
        {
            "scope": ["meta.diff.header", "meta.diff.range"],
            "settings": {
                "foreground": "#6897BB"
            }
        }
    ]
}

{
    "name": "atopile",
    "displayName": "atopile",
    "description": "atopile EDA tooling for VS Code",
    "version": "0.0.0",
    "publisher": "atopile",
    "repository": {
        "type": "git",
        "url": "https://github.com/atopile/atopile.git"
    },
    "engines": {
        "vscode": "^1.105.0"
    },
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "icon": "ato_logo_256x256.png",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "atopile-sidebar",
                    "title": "atopile",
                    "icon": "resources/atopile-icon.svg"
                }
            ],
            "secondarySidebar": [
                {
                    "id": "atopile-agent",
                    "title": "Agent",
                    "icon": "resources/atopile-icon.svg"
                }
            ],
            "panel": [
                {
                    "id": "atopile-logs",
                    "title": "Build",
                    "icon": "resources/atopile-icon.svg"
                }
            ]
        },
        "views": {
            "atopile-sidebar": [
                {
                    "type": "webview",
                    "id": "atopile.sidebarView",
                    "name": ""
                }
            ],
            "atopile-logs": [
                {
                    "type": "webview",
                    "id": "atopile.logsView",
                    "name": "Build"
                }
            ],
            "atopile-agent": [
                {
                    "type": "webview",
                    "id": "atopile.agentView",
                    "name": "Agent",
                    "visibility": "visible",
                    "order": 0
                }
            ]
        },
        "languages": [
            {
                "id": "ato",
                "aliases": [
                    "atopile",
                    "ato"
                ],
                "extensions": [
                    ".ato"
                ],
                "icon": {
                    "dark": "./ato_logo_256x256.png",
                    "light": "./ato_logo_256x256.png"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ato",
                "scopeName": "source.ato",
                "path": "./syntaxes/ato.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "atopile",
            "properties": {
                "atopile.ato": {
                    "type": "string",
                    "default": "",
                    "scope": "machine-overridable",
                    "description": "Full path to a local ato binary. Supports ${workspaceFolder} and ${workspaceRoot} placeholders. When set and valid, the extension uses it instead of the managed uv install."
                },
                "atopile.enableChat": {
                    "type": "boolean",
                    "default": false,
                    "scope": "machine",
                    "description": "Show the AI chat dock in the atopile sidebar."
                }
            }
        },
        "commands": [
            {
                "command": "atopile.openPanel",
                "title": "atopile: Open Panel"
            },
            {
                "command": "atopile.startBuild",
                "title": "atopile: Start Build"
            },
            {
                "command": "atopile.demo-mode",
                "title": "Demo Mode",
                "category": "atopile"
            }
        ],
        "themes": [
            {
                "label": "atopile Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/atopile-dark-color-theme.json"
            }
        ]
    },
    "scripts": {
        "generate:types": "uv run --project ../.. python -m atopile.generate_types",
        "build": "bun run generate:types && cd ../.. && bun build src/vscode-atopile/src/extension.ts --outfile src/vscode-atopile/dist/extension.js --target node --format cjs --external vscode --minify && cd src/ui/webview && bun run build",
        "watch": "bun run generate:types && concurrently \"cd ../.. && bun build src/vscode-atopile/src/extension.ts --outfile src/vscode-atopile/dist/extension.js --target node --format cjs --external vscode --watch\" \"cd ../ui/webview && bun run watch\"",
        "package": "bun run build && vsce package --allow-missing-repository --no-dependencies"
    },
    "dependencies": {
        "glob": "^11.0.0",
        "js-yaml": "^4.1.1",
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.3.2",
        "@types/vscode": "1.105.0",
        "@types/ws": "^8.18.1",
        "@vscode/vsce": "^3.7.1",
        "concurrently": "^9.2.1",
        "typescript": "^5.9.3",
        "ws": "^8.19.0"
    }
}

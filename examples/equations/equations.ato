import ResistorVoltageDivider

module App:
    my_vdiv = new ResistorVoltageDivider

    assert my_vdiv.v_in within 10V +/- 1%
    assert my_vdiv.v_out within 3.3V +/- 10%
    assert my_vdiv.current within 50uA +/- 10%

    my_vdiv.chain.resistors[0].package = "R0402"
    my_vdiv.chain.resistors[1].package = "R0402"
